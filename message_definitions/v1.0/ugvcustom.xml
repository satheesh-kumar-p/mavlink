<?xml version="1.0" encoding="UTF-8"?>
<mavlink>
  <version>2</version>

  <enums>
    <enum name="MAV_TYPE">
      <description>MAVLINK component type reported in HEARTBEAT message.</description>
      <entry value="0" name="MAV_TYPE_GENERIC">
        <description>Generic micro air vehicle</description>
      </entry>
      <entry value="6" name="MAV_TYPE_GCS">
        <description>Ground Control Station terminal node interface</description>
      </entry>
      <entry value="18" name="MAV_TYPE_ONBOARD_CONTROLLER">
        <description>Onboard companion controller</description>
      </entry>
    </enum>

    <enum name="MAV_AUTOPILOT">
      <description>Micro air vehicle / autopilot classes. This identifies the individual model.</description>
      <entry value="0" name="MAV_AUTOPILOT_GENERIC">
        <description>Generic autopilot, full support for everything</description>
      </entry>
      <entry value="8" name="MAV_AUTOPILOT_INVALID">
        <description>No valid autopilot, e.g. a GCS or other MAVLink component</description>
      </entry>
    </enum>

    <enum name="MAV_STATE">
      <entry value="0" name="MAV_STATE_UNINIT">
        <description>Uninitialized system, state is unknown.</description>
      </entry>
      <entry value="3" name="MAV_STATE_STANDBY">
        <description>System is grounded and on standby. It can be launched any time.</description>
      </entry>
      <entry value="4" name="MAV_STATE_ACTIVE">
        <description>System is active. Motors are engaged.</description>
      </entry>
    </enum>

    <enum name="MAV_CMD">
      <description>Commands to be executed by the UGV platform via COMMAND_LONG packet structures.</description>
      <entry value="176" name="MAV_CMD_DO_SET_MODE" hasLocation="false" isDestination="false">
        <description>Set system mode.</description>
        <param index="1" label="Mode" enum="MAV_MODE_FLAG">Mode flags.</param>
        <param index="2" label="Custom Mode" enum="UGV_MAIN_MODE">Main mode selection for UGV</param>
        <param index="3" label="Custom Submode" enum="UGV_SUB_MODE">Sub mode selection for UGV</param>
        <param index="4" label="Speed Submode" enum="UGV_SPEED_MODE">Speed sub mode selection</param>
        <param index="5">Empty</param>
        <param index="6">Empty</param>
        <param index="7">Empty</param>
      </entry>
      <entry value="400" name="MAV_CMD_COMPONENT_ARM_DISARM" hasLocation="false" isDestination="false">
        <description>Arms / Disarms a component</description>
        <param index="1" label="Arm" enum="MAV_BOOL">Arm (MAV_BOOL_FALSE: disarm).</param>
        <param index="2" label="Force" minValue="0" maxValue="21196" increment="21196">0: arm-disarm unless prevented by safety checks, 21196: force arming/disarming</param>
      </entry>
      <entry value="31900" name="MAV_CMD_DRIVE_MODE" hasLocation="false" isDestination="false">
        <description>Command to change drive mode of UGV</description>
        <param index="1" label="Drive Mode Request" enum="UGV_DRIVE_MODE">Drive mode request.</param>
        <param index="2">Empty</param>
        <param index="3">Empty</param>
        <param index="4">Empty</param>
        <param index="5">Empty</param>
        <param index="6">Empty</param>
        <param index="7">Empty</param>
      </entry>
      <entry value="31901" name="MAV_CMD_LIGHT_CONTROL" hasLocation="false" isDestination="false">
        <description>Command to change light state of UGV</description>
        <param index="1" label="Head Light" enum="MAV_BOOL">ON (MAV_BOOL_FALSE: OFF).</param>
        <param index="2" label="Front Fog Light" enum="MAV_BOOL">ON (MAV_BOOL_FALSE: OFF).</param>
        <param index="3" label="Rear Brake Light" enum="MAV_BOOL">ON (MAV_BOOL_FALSE: OFF).</param>
        <param index="4">Empty</param>
        <param index="5">Empty</param>
        <param index="6">Empty</param>
        <param index="7">Empty</param>
      </entry>
      <entry value="31902" name="MAV_CMD_CAMERA_MARKER_CONTROL" hasLocation="false" isDestination="false">
        <description>Commands the UGV to select a specific camera stream and toggle overlay range markers.</description>
        <param index="1" label="Camera Selection" enum="ICD_CAMERA_STREAM">Select camera index channel stream [1-4].</param>
        <param index="2" label="Range Markers" enum="MAV_BOOL">Toggle layout overlay indicators (0: OFF, 1: ON).</param>
        <param index="3">Empty</param>
        <param index="4">Empty</param>
        <param index="5">Empty</param>
        <param index="6">Empty</param>
        <param index="7">Empty</param>
      </entry>
    </enum>

    <enum name="MAV_RESULT">
      <entry value="0" name="MAV_RESULT_ACCEPTED"/>
      <entry value="1" name="MAV_RESULT_TEMPORARILY_REJECTED"/>
      <entry value="2" name="MAV_RESULT_DENIED"/>
      <entry value="3" name="MAV_RESULT_UNSUPPORTED"/>
      <entry value="4" name="MAV_RESULT_FAILED"/>
      <entry value="5" name="MAV_RESULT_IN_PROGRESS"/>
      <entry value="6" name="MAV_RESULT_CANCELLED"/>
    </enum>

    <enum name="MAV_BOOL">
      <entry value="0" name="MAV_BOOL_FALSE"/>
      <entry value="1" name="MAV_BOOL_TRUE"/>
    </enum>

    <enum name="MAV_MODE_FLAG" bitmask="true">
      <entry value="128" name="MAV_MODE_FLAG_SAFETY_ARMED"/>
      <entry value="64" name="MAV_MODE_FLAG_MANUAL_INPUT_ENABLED"/>
      <entry value="1" name="MAV_MODE_FLAG_CUSTOM_MODE_ENABLED"/>
    </enum>

    <enum name="UGV_MAIN_MODE">
      <entry value="1" name="MODE_A">
        <description>Mode A, Hand Controller</description>
      </entry>
      <entry value="2" name="MODE_B">
        <description>Mode B, GCS</description>
      </entry>
    </enum>

    <enum name="UGV_SUB_MODE">
      <entry value="0" name="NONE"/>
      <entry value="10" name="HOLD"/>
    </enum>

    <enum name="UGV_SPEED_MODE">
      <entry value="1" name="LOW"/>
      <entry value="2" name="MEDIUM"/>
      <entry value="3" name="HIGH"/>
    </enum>

    <enum name="UGV_DRIVE_MODE">
      <entry value="1" name="SPEED"/>
      <entry value="2" name="TORQUE"/>
      <entry value="3" name="TORQUE_WITH_SPEED_LIMIT"/>
      <entry value="4" name="POSITION"/>
    </enum>

    <enum name="MODE_CHANGE_REASON">
      <entry value="0" name="GCS_COMMAND"/>
      <entry value="1" name="FAILSAFE"/>
      <entry value="2" name="SENSOR_FAULT"/>
      <entry value="3" name="COMM_LOSS"/>
    </enum>

    <enum name="UGV_HEALTH_STATE">
      <entry value="0" name="RESERVED_STATE"/>
      <entry value="1" name="NO_COMMUNICATION_STATE"/>
      <entry value="2" name="COMMUNICATING_HEALTHY_STATE"/>
      <entry value="3" name="FAULT_STATE"/>
    </enum>

    <enum name="UGV_MOTOR_ERROR" bitmask="true">
      <entry value="1" name="UGV_MOTOR_ERROR_OVER_SPEED"/>
      <entry value="2" name="UGV_MOTOR_ERROR_OVERLOAD"/>
      <entry value="4" name="UGV_MOTOR_ERROR_PHASE_LOSS"/>
      <entry value="8" name="UGV_MOTOR_ERROR_BRAKE_FAULT"/>
      <entry value="16" name="UGV_MOTOR_ERROR_ENCODER_FAULT"/>
      <entry value="32" name="UGV_MOTOR_ERROR_OVER_TEMPERATURE"/>
      <entry value="64" name="UGV_MOTOR_ERROR_HALL_FAULT"/>
      <entry value="128" name="UGV_MOTOR_ERROR_STALLED"/>
    </enum>

    <enum name="UGV_MOTOR_CTRL_ERROR" bitmask="true">
      <entry value="1" name="UGV_MOTOR_CTRL_ERROR_DRIVE"/>
      <entry value="2" name="UGV_MOTOR_CTRL_ERROR_OVER_CURRENT"/>
      <entry value="4" name="UGV_MOTOR_CTRL_ERROR_OVER_PRESSURE"/>
      <entry value="8" name="UGV_MOTOR_CTRL_ERROR_UNDER_VOLTAGE"/>
      <entry value="16" name="UGV_MOTOR_CTRL_ERROR_OVER_TEMPERATURE"/>
      <entry value="32" name="UGV_MOTOR_CTRL_ERROR_CAN_COMM"/>
    </enum>

    <enum name="ICD_CAMERA_STREAM">
      <entry value="0" name="ICD_CAMERA_RESERVED"/>
      <entry value="1" name="ICD_CAMERA_STREAM_1"/>
      <entry value="2" name="ICD_CAMERA_STREAM_2"/>
      <entry value="3" name="ICD_CAMERA_STREAM_3"/>
      <entry value="4" name="ICD_CAMERA_STREAM_4"/>
    </enum>

    <enum name="GPS_FIX_TYPE">
      <entry value="0" name="GPS_FIX_TYPE_NO_GPS"/>
      <entry value="1" name="GPS_FIX_TYPE_NO_FIX"/>
      <entry value="2" name="GPS_FIX_TYPE_3D_FIX"/>
      <entry value="3" name="GPS_FIX_TYPE_2D_FIX"/>
      <entry value="4" name="GPS_FIX_TYPE_DGPS"/>
      <entry value="5" name="GPS_FIX_TYPE_RTK_FLOAT"/>
      <entry value="6" name="GPS_FIX_TYPE_RTK_FIXED"/>
    </enum>
  </enums>

  <messages>
    <message id="0" name="HEARTBEAT">
      <field type="uint8_t" name="type" enum="MAV_TYPE"/>
      <field type="uint8_t" name="autopilot" enum="MAV_AUTOPILOT"/>
      <field type="uint8_t" name="base_mode" enum="MAV_MODE_FLAG"/>
      <field type="uint32_t" name="custom_mode"/>
      <field type="uint8_t" name="system_status" enum="MAV_STATE"/>
      <field type="uint8_t_mavlink_version" name="mavlink_version"/>
    </message>

    <message id="2" name="SYSTEM_TIME">
      <field type="uint64_t" name="time_unix_usec" units="us"/>
      <field type="uint32_t" name="time_boot_ms" units="ms"/>
    </message>

    <message id="24" name="GPS_RAW_INT">
      <description>Transmits raw, unfiltered GNSS positioning data directly across telemetry broadcasts.</description>
      <field type="uint64_t" name="time_usec" units="us"/>
      <field type="int32_t" name="lat">Latitude (WGS84), expressed in degrees * 1E7</field>
      <field type="int32_t" name="lon">Longitude (WGS84), expressed in degrees * 1E7</field>
      <field type="int32_t" name="alt" units="mm">Altitude (MSL). Expressed in millimeters.</field>
      <field type="uint16_t" name="eph">Accuracy of horizontal position, Multiplied by 100</field>
      <field type="uint16_t" name="epv">Accuracy of vertical position, Multiplied by 100 [Not Used]</field>
      <field type="uint16_t" name="vel" units="cm/s">Speed of vehicle calculated by GNSS, Expressed in cm/s</field>
      <field type="uint16_t" name="cog" units="cdeg">Direction of movement, Unit: Centidegree (divide by 100 for raw value)</field>
      <field type="uint8_t" name="fix_type" enum="GPS_FIX_TYPE">GNSS fix quality mapping indicator profile.</field>
      <field type="uint8_t" name="satellites_visible">Number of satellites visible to tracking matrix hardware.</field>
    </message>

    <message id="69" name="MANUAL_CONTROL">
      <field type="uint8_t" name="target"/>
      <field type="int16_t" name="x"/>
      <field type="int16_t" name="y"/>
      <field type="int16_t" name="z"/>
      <field type="int16_t" name="r"/>
      <field type="uint16_t" name="buttons"/>
      <extensions/>
      <field type="uint8_t" name="enabled_extensions"/>
      <field type="int16_t" name="s"/>
      <field type="int16_t" name="t"/>
      <field type="int16_t" name="aux1"/>
      <field type="int16_t" name="aux2"/>
      <field type="int16_t" name="aux3"/>
      <field type="int16_t" name="aux4"/>
      <field type="int16_t" name="aux5"/>
      <field type="int16_t" name="aux6"/>
    </message>

    <message id="76" name="COMMAND_LONG">
      <field type="uint8_t" name="target_system"/>
      <field type="uint8_t" name="target_component"/>
      <field type="uint16_t" name="command" enum="MAV_CMD"/>
      <field type="uint8_t" name="confirmation"/>
      <field type="float" name="param1"/>
      <field type="float" name="param2"/>
      <field type="float" name="param3"/>
      <field type="float" name="param4"/>
      <field type="float" name="param5"/>
      <field type="float" name="param6"/>
      <field type="float" name="param7"/>
    </message>

    <message id="77" name="COMMAND_ACK">
      <field type="uint16_t" name="command" enum="MAV_CMD"/>
      <field type="uint8_t" name="result" enum="MAV_RESULT"/>
      <extensions/>
      <field type="uint8_t" name="progress" units="%"/>
      <field type="int32_t" name="result_param2"/>
      <field type="uint8_t" name="target_system"/>
      <field type="uint8_t" name="target_component"/>
    </message>

    <message id="109" name="RADIO_STATUS">
      <field type="uint8_t" name="rssi"/>
      <field type="uint8_t" name="remrssi"/>
      <field type="uint8_t" name="txbuf" units="%"/>
      <field type="uint8_t" name="noise"/>
      <field type="uint8_t" name="remnoise"/>
      <field type="uint16_t" name="rxerrors"/>
      <field type="uint16_t" name="fixed"/>
    </message>

    <message id="111" name="TIMESYNC">
      <field type="int64_t" name="tc1" units="ns"/>
      <field type="int64_t" name="ts1" units="ns"/>
      <extensions/>
      <field type="uint8_t" name="target_system"/>
      <field type="uint8_t" name="target_component"/>
    </message>

    <message id="50001" name="UGV_SYSTEM_INFO">
      <description>Reports comprehensive subsystem tracking and diagnostic status profiles of the UGV hardware layer.</description>

      <field type="uint8_t" name="ts1_hour"></field>
      <field type="uint8_t" name="ts1_minute"></field>
      <field type="uint8_t" name="ts1_second"></field>

      <field type="uint8_t" name="subsystem_health_1" enum="UGV_HEALTH_STATE">
          Bit 0-1 : Left Motor Controller Health
          Bit 2-3 : Right Motor Controller Health
          Bit 4-5 : HV Battery Health
          Bit 6-7 : LV Battery Health
      </field>
      <field type="uint8_t" name="subsystem_health_2" enum="UGV_HEALTH_STATE">
        Bit 0-1 : LV PDU
        Bit 2-3 : DC-DC 48V to 12V
        Bit 4-5 : DC-DC 12V to 5V
        Bit 6-7 : VCU
      </field>
      <field type="uint8_t" name="subsystem_health_3" enum="UGV_HEALTH_STATE">
        Bit 0-1 : Front Left Motor
        Bit 2-3 : Rear Left Motor
        Bit 4-5 : Front Right Motor
        Bit 6-7 : Rear Right Motor
      </field>
      <field type="uint8_t" name="subsystem_health_4" enum="UGV_HEALTH_STATE">
        Bit 0-1 : UHF Radio
        Bit 2-3 : LBAND Radio
        Bit 4-5 : Compute
        Bit 6-7 : Reserved
      </field>

      <field type="uint8_t" name="ts2_hour"></field>
      <field type="uint8_t" name="ts2_minute"></field>
      <field type="uint8_t" name="ts2_second"></field>

      <field type="uint8_t" name="battery_soc" units="%">State of Charge remaining percentage metric.</field>

      <field type="uint8_t" name="lv_battery_voltage">NEW IN V1.1: Secondary low-voltage battery system monitoring line [Scale: 0.1 V]</field>

      <field type="uint8_t" name="main_mode" enum="UGV_MAIN_MODE"/>
      <field type="uint8_t" name="sub_mode" enum="UGV_SUB_MODE"/>
      <field type="uint8_t" name="speed_mode" enum="UGV_SPEED_MODE"/>
      <field type="uint8_t" name="drive_mode" enum="UGV_DRIVE_MODE"/>
      <field type="uint8_t" name="arm_mode" enum="MAV_BOOL"/>
      <field type="uint8_t" name="intended_main_mode" enum="UGV_MAIN_MODE"/>
      <field type="uint8_t" name="intended_sub_mode" enum="UGV_SUB_MODE"/>
      <field type="uint8_t" name="intended_speed_mode" enum="UGV_SPEED_MODE"/>
      <field type="uint8_t" name="intended_drive_mode" enum="UGV_DRIVE_MODE"/>
      <field type="uint8_t" name="intended_arm_mode" enum="MAV_BOOL"/>
      <field type="uint8_t" name="mode_change_reason" enum="MODE_CHANGE_REASON"/>

      <field type="uint8_t" name="ts3_hour"></field>
      <field type="uint8_t" name="ts3_minute"></field>
      <field type="uint8_t" name="ts3_second"></field>

      <field type="uint8_t" name="rear_left_motor_faults" enum="UGV_MOTOR_ERROR"/>
      <field type="uint8_t" name="rear_right_motor_faults" enum="UGV_MOTOR_ERROR"/>
      <field type="uint8_t" name="front_left_motor_faults" enum="UGV_MOTOR_ERROR"/>
      <field type="uint8_t" name="front_right_motor_faults" enum="UGV_MOTOR_ERROR"/>

      <field type="uint8_t" name="rear_mc_faults" enum="UGV_MOTOR_CTRL_ERROR"/>
      <field type="uint8_t" name="front_mc_faults" enum="UGV_MOTOR_CTRL_ERROR"/>

      <field type="uint8_t" name="rear_mc_voltage" units="0.1V"/>
      <field type="uint8_t" name="front_mc_voltage" units="0.1V"/>
      <field type="uint8_t" name="rear_mc_temperature" units="degC"/>
      <field type="uint8_t" name="front_mc_temperature" units="degC"/>

      <field type="uint8_t" name="light_status">
        bit 0: head light state
        bit 1: front fog light state
        bit 2: rear light state
      </field>
      <field type="uint8_t" name="pdu_channel_status">
        bit 0: lv pdu channel 1 state
        bit 1: lv pdu channel 2 state
        bit 2: lv pdu channel 3 state
        bit 3: lv pdu channel 4 state
        bit 4: lv pdu channel 5 state
        bit 5: lv pdu channel 6 state
        bit 6: lv pdu channel 7 state
        bit 7: lv pdu channel 8 state
      </field>
    </message>

  </messages>
</mavlink>